import kotlinx.coroutines.launch

@Composable
fun DynamicTableScreen(
    configFile: String,          // pass JSON filename
    onBack: () -> Unit
) {
    val scope = rememberCoroutineScope()
    val authService = remember { AuthService() }

    // load config from JSON
    val config = remember { TableConfigLoader.load(configFile) }
    val visibleColumns = config.columns.filter { it.visible }
    var successMsg    by remember { mutableStateOf("") }
    // state
    var rows       by remember { mutableStateOf<List<Map<String, String>>>(emptyList()) }
    var isLoading  by remember { mutableStateOf(false) }
    var errorMsg   by remember { mutableStateOf("") }
    var searchText by remember { mutableStateOf("") }
    var showAddDialog by remember { mutableStateOf(false) }
    // add this state at top of DynamicTableScreen
    var editingRow by remember { mutableStateOf<Map<String, String>?>(null) }
    // load all rows
    fun loadAll() {
        scope.launch {
            isLoading = true
            errorMsg = ""
            try {
                rows = authService.getAllRows(config.apiBase)
            } catch (e: Exception) {
                errorMsg = "Failed: ${e.message}"
            } finally {
                isLoading = false
            }
        }
    }

    // delete row
    fun deleteRow(id: String) {
        scope.launch {
            try {
                authService.deleteRow(config.apiBase, id)
                loadAll()
            } catch (e: Exception) {
                errorMsg = "Delete failed: ${e.message}"
            }
        }
    }

    // search
    fun search() {
        scope.launch {
            isLoading = true
            try {
                rows = if (searchText.isBlank())
                    authService.getAllRows(config.apiBase)
                else
                    authService.searchRows(config.apiBase, searchText)
            } catch (e: Exception) {
                errorMsg = "Search failed: ${e.message}"
            } finally {
                isLoading = false
            }
        }
    }

    LaunchedEffect(Unit) { loadAll() }

    // Add Dialog
    if (showAddDialog) {
        DynamicAddDialog(
            columns = config.columns.filter { it.editable },
            onDismiss = { showAddDialog = false },
            onSave = { formData ->
                scope.launch {
                    try {
                        authService.addRow(config.apiBase, formData)
                        showAddDialog = false
                        loadAll()    // ← reactive update
                    } catch (e: Exception) {
                        errorMsg = "Add failed: ${e.message}"
                    }
                }
            }
        )
    }

    // ── EDIT DIALOG ──
    editingRow?.let { row ->
        DynamicEditDialog(
            row = row,
            columns = config.columns.filter { it.editable },
            onDismiss = { editingRow = null },
            onSave = { formData ->
                scope.launch {
                    try {
                        authService.updateRow(config.apiBase, formData)
                        editingRow = null
                        successMsg = "Record updated successfully"
                        loadAll()
                    } catch (e: Exception) {
                        errorMsg = "Update failed: ${e.message}"
                    }
                }
            }
        )
    }

    Column(modifier = Modifier.fillMaxSize().padding(32.dp)) {

        // TOP BAR
        Row(
            modifier = Modifier.fillMaxWidth(),
            horizontalArrangement = Arrangement.SpaceBetween,
            verticalAlignment = Alignment.CenterVertically
        ) {
            Text(config.displayName, style = MaterialTheme.typography.headlineMedium)
            OutlinedButton(onClick = onBack) { Text("Back") }
        }

        Spacer(Modifier.height(16.dp))
        HorizontalDivider()
        Spacer(Modifier.height(12.dp))

        // SEARCH + ADD ROW
        Row(
            horizontalArrangement = Arrangement.spacedBy(12.dp),
            verticalAlignment = Alignment.CenterVertically
        ) {
            if (config.searchable) {
                OutlinedTextField(
                    value = searchText,
                    onValueChange = { searchText = it },
                    label = { Text("Search") },
                    singleLine = true,
                    modifier = Modifier.width(240.dp)
                )
                Button(onClick = { search() }) { Text("Search") }
                OutlinedButton(onClick = { searchText = ""; loadAll() }) { Text("Reset") }
            }

            Spacer(Modifier.weight(1f))

            if (config.canAdd) {
                Button(onClick = { showAddDialog = true }) { Text("+ Add") }
            }
        }

        Spacer(Modifier.height(12.dp))

        // TABLE HEADER — built from JSON columns
        Row(
            modifier = Modifier
                .fillMaxWidth()
                .background(MaterialTheme.colorScheme.primary)
                .padding(horizontal = 16.dp, vertical = 10.dp)
        ) {
            visibleColumns.forEach { col ->
                Text(
                    col.label,
                    color = Color.White,
                    modifier = Modifier.weight(1f),
                    fontWeight = FontWeight.Bold,
                    fontSize = 13.sp
                )
            }
            if (config.canDelete) {
                Text("Action", color = Color.White, modifier = Modifier.width(80.dp), fontWeight = FontWeight.Bold, fontSize = 13.sp)
            }
        }

        // TABLE BODY — built from JSON data
        when {
            isLoading -> {
                Box(Modifier.fillMaxWidth().padding(32.dp), contentAlignment = Alignment.Center) {
                    CircularProgressIndicator()
                }
            }
            errorMsg.isNotEmpty() -> {
                Text(errorMsg, color = MaterialTheme.colorScheme.error, modifier = Modifier.padding(16.dp))
            }
            rows.isEmpty() -> {
                Text("No data found.", modifier = Modifier.padding(16.dp), color = Color.Gray)
            }
            else -> {
                LazyColumn(modifier = Modifier.fillMaxWidth().weight(1f)) {
                    itemsIndexed(rows) { index, row ->
                        Row(
                            modifier = Modifier
                                .fillMaxWidth()
                                .background(if (index % 2 == 0) Color(0xFFF5F5F5) else Color.White)
                                .padding(horizontal = 16.dp, vertical = 8.dp),
                            verticalAlignment = Alignment.CenterVertically
                        ) {
                            // render each cell based on JSON column config
                            visibleColumns.forEach { col ->
                                Text(
                                    row[col.key] ?: "",
                                    modifier = Modifier.weight(1f),
                                    fontSize = 13.sp
                                )
                            }
                            //edit button
                            if (config.canEdit) {
                                TextButton(
                                    onClick = { editingRow = row }  // ← sets editingRow state
                                ) {
                                    Text("Edit", fontSize = 12.sp)
                                }
                            }
                            // delete button
                            if (config.canDelete) {
                                TextButton(
                                    onClick = { deleteRow(row["id"] ?: "") },
                                    modifier = Modifier.width(80.dp)
                                ) {
                                    Text("Delete", color = MaterialTheme.colorScheme.error, fontSize = 12.sp)
                                }
                            }
                        }
                        HorizontalDivider(color = Color(0xFFEEEEEE))
                    }
                }
            }
        }
    }
}

// DYNAMIC ADD DIALOG — fields built from JSON
@Composable
fun DynamicAddDialog(
    columns: List<ColumnConfig>,
    onDismiss: () -> Unit,
    onSave: (Map<String, String>) -> Unit
) {
    // create form state dynamically from columns
    val formData = remember {
        mutableStateMapOf<String, String>().apply {
            columns.forEach { put(it.key, "") }
        }
    }

    AlertDialog(
        onDismissRequest = onDismiss,
        title = { Text("Add New Row") },
        text = {
            Column(verticalArrangement = Arrangement.spacedBy(8.dp)) {
                // render one input per editable column
                columns.forEach { col ->
                    OutlinedTextField(
                        value = formData[col.key] ?: "",
                        onValueChange = { formData[col.key] = it },
                        label = { Text(col.label) },
                        singleLine = true
                    )
                }
            }
        },
        confirmButton = {
            Button(onClick = { onSave(formData.toMap()) }) { Text("Save") }
        },
        dismissButton = {
            OutlinedButton(onClick = onDismiss) { Text("Cancel") }
        }
    )
}
@Composable
fun DynamicEditDialog(
    row: Map<String, String>,
    columns: List<ColumnConfig>,
    onDismiss: () -> Unit,
    onSave: (Map<String, String>) -> Unit
) {
    val formData = remember {
        mutableStateMapOf<String, String>().apply {
            columns.forEach { col ->
                put(col.key, row[col.key] ?: "")  // pre fills existing data
            }
        }
    }

    AlertDialog(
        onDismissRequest = onDismiss,
        title = { Text("Edit Record") },
        text = {
            Column(verticalArrangement = Arrangement.spacedBy(8.dp)) {
                columns.forEach { col ->
                    OutlinedTextField(
                        value = formData[col.key] ?: "",
                        onValueChange = { formData[col.key] = it },
                        label = { Text(col.label) },
                        placeholder = {
                            if (col.type == "date") Text("YYYY-MM-DD", color = Color.Gray)
                        },
                        singleLine = true
                    )
                }
            }
        },
        confirmButton = {
            Button(onClick = {
                val updatedData = formData.toMutableMap()
                updatedData["id"] = row["id"] ?: ""
                onSave(updatedData)
            }) { Text("Save") }
        },
        dismissButton = {
            OutlinedButton(onClick = onDismiss) { Text("Cancel") }
        }
    )
}







